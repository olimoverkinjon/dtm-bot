# 🔐 DTM Bot - Environment Configuration
# Copy this file to .env and fill in your values

# ==========================================
# Required Configuration
# ==========================================

# Telegram Bot API Token
# Get from BotFather: https://t.me/BotFather
API_TOKEN=your_bot_token_here_8516827967_AAHDYsWDsYrsM3HBna24ceonbpM9a8zb_Yw

# Telegram Channel Username (for subscription check)
# Example: @registan_abituriyent
CHANNEL_USERNAME=@your_channel_name_here

# Group ID (where to send notifications)
# Use @userinfobot to get the ID
GROUP_ID=-1003890628671

# Admin User ID (who can use /admin command)
# Send /start to bot, check logs for your user_id
ADMIN_ID=6653845419

# ==========================================
# Optional Configuration
# ==========================================

# Port for status dashboard
# Default: 8000
PORT=8000

# Status server port
# Default: 8000
STATUS_PORT=8000

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# Default: INFO
LOG_LEVEL=INFO

# Mode: polling or webhook
# Default: polling (recommended for testing)
# webhook requires WEBHOOK_URL
BOT_MODE=polling

# Webhook URL (only needed if BOT_MODE=webhook)
# Example: https://yourdomain.com/webhook
WEBHOOK_URL=https://your-domain.com/webhook

# ==========================================
# How to Get These Values
# ==========================================

# API_TOKEN:
#   1. Open Telegram
#   2. Message @BotFather
#   3. Create new bot
#   4. Copy the token

# CHANNEL_USERNAME:
#   1. Create a public channel
#   2. Copy the username (starts with @)
#   3. Example: @my_channel

# GROUP_ID:
#   1. Add bot to a group
#   2. Forward any message to @userinfobot
#   3. Copy the chat_id (negative number)

# ADMIN_ID:
#   1. Send /start to the bot
#   2. Check console logs for "user_id"
#   3. Or use @userinfobot in private chat

# ==========================================
# Setup Instructions
# ==========================================

# 1. Rename this file to .env
#    mv .env.example .env
#
# 2. Replace placeholder values with your actual values
#
# 3. Save the file
#
# 4. Run the bot
#    python main.py
#
# 5. Test by sending /start to your bot on Telegram

# ==========================================
# Testing Checklist
# ==========================================

# After setup, test:
# ✅ Bot responds to /start
# ✅ Subscription check works
# ✅ Registration flow completes
# ✅ Leads are saved (check leads.json)
# ✅ Admin can use /admin command
# ✅ Status dashboard works (http://localhost:8000)

# ==========================================
# Troubleshooting
# ==========================================

# Bot not responding?
# - Check API_TOKEN is correct
# - Make sure bot is still running
# - Check logs for errors

# Subscription check failing?
# - Verify CHANNEL_USERNAME is correct (with @)
# - User must be subscribed to channel
# - Bot must be member of channel

# Leads not saved?
# - Check WRITE permissions on folder
# - Make sure leads.json exists
# - Check for disk space

# More help: See README_PYTHON.md
